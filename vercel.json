{
  "version": 2,
  "name": "folio-ai-api",
  "functions": {
    "api/chat.js": {
      "maxDuration": 30
    },
    "api/generate-insight.js": {
      "maxDuration": 45
    },
    "api/health.js": {
      "maxDuration": 5
    },
    "api/generate-book.js": {
      "maxDuration": 45
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
